# -----------------------------
# Stellanet Backend Environment
# -----------------------------

# Core
AWS_REGION=us-east-1
NOVA_TEXT_MODEL_ID=global.amazon.nova-2-lite-v1:0
OPENALEX_MAILTO=your-email@example.com

# AWS Bedrock credentials (required for real Nova responses)
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY

# Database
# For local SQLite, leave DATABASE_URL empty and optionally set AUTH_DB_PATH.
DATABASE_URL=
AUTH_DB_PATH=./auth.db

# For AWS RDS PostgreSQL, set DATABASE_URL and DB_SSL_ROOT_CERT:
# DATABASE_URL=postgresql://USER:PASSWORD@your-instance.rds.amazonaws.com:5432/postgres
# DB_SSL_ROOT_CERT=./global-bundle.pem
DB_SSL_ROOT_CERT=

# Auth safety (keep false in production)
AUTH_EXPOSE_TOKENS=false

# Frontend origin(s) used for CORS/email links
FRONTEND_URL=http://localhost:5173
# FRONTEND_URLS=http://localhost:5173,http://127.0.0.1:5173

# OAuth (optional: Google)
# Comma-separated list of allowed Google Web client IDs.
GOOGLE_OAUTH_CLIENT_IDS=

# Contact form inbox (where website messages are delivered)
CONTACT_TO_EMAIL=info@yourdomain.com

# Email delivery (choose ONE method)

# Option A: Resend API (recommended)
RESEND_API_KEY=
RESEND_FROM=noreply@yourdomain.com

# Option B: SMTP fallback
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com
SMTP_USE_TLS=true
